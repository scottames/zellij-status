// Vertical example â€” full-featured left sidebar with Tokyo Night theme.
//
// LAYOUT ZONES
// In vertical mode the sidebar is divided into three zones stacked top to
// bottom: "top", "middle", and "bottom". The middle zone holds the {tabs}
// widget and expands to fill all remaining vertical space between the top
// and bottom zones.
//
// ROWS WITHIN A ZONE
// Each zone can have multiple rows. The number prefix (format_1_, format_2_,
// etc.) controls the row order within that zone. For example:
//   format_1_top  â†’ first row in the top zone  (datetime + notifications)
//   format_2_top  â†’ second row in the top zone (session name)
//
// SPLIT ROWS (LEFT / RIGHT)
// Appending _left or _right to a format key splits that row into two halves.
// Content in _left is pinned to the left edge; _right is pinned to the right.
// The gap between them is filled by whichever side has `fill` set.
//   format_1_bottom_left  "{mode}"       â†’ mode label on the left
//   format_1_bottom_right "{mode_cap}"   â†’ powerline arrow pinned right
//
// FILL DIRECTIVE
// Adding `fill` to a style directive (e.g. #[bg=$blue,fill]) tells the
// renderer to stretch that segment's background colour across all remaining
// space in the row. This is how the mode bar and active tab get a full-width
// coloured stripe.
//
// CAPS ({widget}_cap)
// A "cap" is an auto-generated powerline arrow that transitions between two
// colours: the widget's fill background and `cap_bg`. For example,
// {mode_cap} renders an arrow whose foreground is the mode's bg colour
// (e.g. blue for NORMAL) and whose background is cap_bg ($base), creating
// a smooth colour transition at the edge of the mode bar.
//
// COLOR ALIASES
// The color_* keys define named aliases (Tokyo Night palette here). Use
// $name in style directives to reference them, e.g. $blue â†’ #7aa2f7.
//
// TAB FORMAT STRINGS
// In vertical mode each tab is one row. The format string is a sequence of
// styled segments. Powerline arrows (U+E0B0 ) at the start/end of a tab
// row create the angled cap effect. The `fill` on the trailing segment
// stretches the background between the tab content and the trailing arrow.
//
// WHY VERTICAL LAYOUTS NEED new_tab_template
// Zellij's fallback from new_tab_template to default_tab_template only finds
// `children` at the template level. Vertical layouts nest `children` inside
// `pane split_direction="vertical"`, so the fallback misses it and new tabs
// fail. Defining new_tab_template explicitly works because `children` inside
// a pane node is accepted.

layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=26 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Tokyo Night palette --
                    color_rosewater "#89ddff"
                    color_flamingo  "#ff007c"
                    color_pink      "#9d7cd8"
                    color_mauve     "#bb9af7"
                    color_red       "#f7768e"
                    color_maroon    "#db4b4b"
                    color_peach     "#ff9e64"
                    color_yellow    "#e0af68"
                    color_green     "#9ece6a"
                    color_teal      "#73daca"
                    color_sky       "#7dcfff"
                    color_sapphire  "#2ac3de"
                    color_blue      "#7aa2f7"
                    color_lavender  "#b4f9f8"
                    color_text      "#c0caf5"
                    color_subtext1  "#a9b1d6"
                    color_subtext0  "#a9b1d6"
                    color_overlay2  "#565f89"
                    color_overlay1  "#737aa2"
                    color_overlay0  "#545c7e"
                    color_surface2  "#414868"
                    color_surface1  "#3b4261"
                    color_surface0  "#292e42"
                    color_base      "#1a1b26"
                    color_mantle    "#16161e"
                    color_crust     "#13131a"

                    // --- Zones ---

                    // Top zone, row 1: datetime on the left and notifications on
                    // the right in a shared bar. _right pins notifications to the
                    // edge; fill stretches the $surface1 background across the row.
                    format_1_top_left  "#[bg=$surface1,fg=$text,bold,fill] {datetime} "
                    format_1_top_right "#[bg=$surface1] {notifications}"

                    // Top zone, row 2: session name.
                    format_2_top_left  "#[fg=$overlay1] {session}"

                    // Middle zone: the {tabs} anchor. The tab list fills all
                    // vertical space between the top and bottom zones. _left
                    // means tab text is left-aligned within each row.
                    format_1_middle_left "{tabs}"

                    // Bottom zone: split row â€” mode label on the left, its
                    // powerline cap arrow on the right. The mode widget has
                    // fill set, so its bg stretches to meet the cap arrow.
                    format_1_bottom_left  "{mode}"
                    format_1_bottom_right "{mode_cap}"

                    // Cap background: the colour "behind" powerline arrows.
                    // The arrow's fg comes from the widget's fill bg, and its
                    // bg is cap_bg â€” together they create the colour transition.
                    cap_bg "$base"

                    // --- Tab format strings ---
                    // Each tab is rendered as one row. The format is a chain
                    // of styled segments:
                    //   [leading arrow][index][thin divider][name][trailing arrow]
                    // The leading  (U+E0B0) creates a left-edge powerline cap.
                    // The trailing  pins to the right edge. `fill` on the
                    // content segment stretches its bg to meet the trailing arrow.
                    // Normal tabs use $base bg; active tabs use $green bg.
                    tab_normal              "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} {notification} #[fg=$base]î‚°"
                    tab_active              "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} {notification} #[fg=$green]î‚°"
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} َ°ٹ“ {notification} #[fg=$base]î‚°"
                    tab_active_fullscreen   "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} َ°ٹ“ {notification} #[fg=$green]î‚°"
                    tab_normal_sync         "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} َ°»† {notification} #[fg=$base]î‚°"
                    tab_active_sync         "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} َ°»† {notification} #[fg=$green]î‚°"
                    tab_separator           "#[bg=$mantle,fg=$overlay0]"

                    tab_sync_indicator       "َ°»†"
                    tab_fullscreen_indicator "َ°ٹ“"
                    tab_floating_indicator   "َ°¶™"

                    // Shown when tabs overflow the available rows. {count}
                    // is replaced with the number of hidden tabs.
                    overflow_above "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length 20
                    start_index     1
                    padding_top 0

                    // Right-edge separator between the sidebar and content pane.
                    border "#[fg=$surface1]â”‚"

                    // --- Notifications ---
                    notification_enabled        "true"
                    notification_icon_waiting   "َ°ˆ…"
                    notification_icon_in_progress "َ°‡ک"
                    notification_icon_completed "ï€Œ"
                    notification_format         "#[bg=$surface1,fg=$peach,bold] {count} "
                    notification_show_if_empty  "false"

                    // --- Mode widget ---
                    // Each Zellij mode gets its own accent colour. The `fill`
                    // directive stretches the bg across the row, and {mode_cap}
                    // (in the bottom zone) auto-derives its arrow colour from
                    // whichever mode is active.
                    mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                    mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                    mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                    mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                    mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                    mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                    mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                    mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                    mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                    mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                    mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                    mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "

                    // --- DateTime ---
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"
                }
            }
            children
        }
    }

    // Required for vertical layouts â€” see header comment for why.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=26 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Tokyo Night palette --
                    color_rosewater "#89ddff"
                    color_flamingo  "#ff007c"
                    color_pink      "#9d7cd8"
                    color_mauve     "#bb9af7"
                    color_red       "#f7768e"
                    color_maroon    "#db4b4b"
                    color_peach     "#ff9e64"
                    color_yellow    "#e0af68"
                    color_green     "#9ece6a"
                    color_teal      "#73daca"
                    color_sky       "#7dcfff"
                    color_sapphire  "#2ac3de"
                    color_blue      "#7aa2f7"
                    color_lavender  "#b4f9f8"
                    color_text      "#c0caf5"
                    color_subtext1  "#a9b1d6"
                    color_subtext0  "#a9b1d6"
                    color_overlay2  "#565f89"
                    color_overlay1  "#737aa2"
                    color_overlay0  "#545c7e"
                    color_surface2  "#414868"
                    color_surface1  "#3b4261"
                    color_surface0  "#292e42"
                    color_base      "#1a1b26"
                    color_mantle    "#16161e"
                    color_crust     "#13131a"

                    // --- Zones ---

                    // Top zone, row 1: datetime on the left and notifications on
                    // the right in a shared bar. _right pins notifications to the
                    // edge; fill stretches the $surface1 background across the row.
                    format_1_top_left  "#[bg=$surface1,fg=$text,bold,fill] {datetime} "
                    format_1_top_right "#[bg=$surface1] {notifications}"

                    // Top zone, row 2: session name.
                    format_2_top_left  "#[fg=$overlay1] {session}"

                    // Middle zone: the {tabs} anchor. The tab list fills all
                    // vertical space between the top and bottom zones. _left
                    // means tab text is left-aligned within each row.
                    format_1_middle_left "{tabs}"

                    // Bottom zone: split row â€” mode label on the left, its
                    // powerline cap arrow on the right. The mode widget has
                    // fill set, so its bg stretches to meet the cap arrow.
                    format_1_bottom_left  "{mode}"
                    format_1_bottom_right "{mode_cap}"

                    // Cap background: the colour "behind" powerline arrows.
                    // The arrow's fg comes from the widget's fill bg, and its
                    // bg is cap_bg â€” together they create the colour transition.
                    cap_bg "$base"

                    // --- Tab format strings ---
                    // Each tab is rendered as one row. The format is a chain
                    // of styled segments:
                    //   [leading arrow][index][thin divider][name][trailing arrow]
                    // The leading  (U+E0B0) creates a left-edge powerline cap.
                    // The trailing  pins to the right edge. `fill` on the
                    // content segment stretches its bg to meet the trailing arrow.
                    // Normal tabs use $base bg; active tabs use $green bg.
                    tab_normal              "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} {notification} #[fg=$base]î‚°"
                    tab_active              "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} {notification} #[fg=$green]î‚°"
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} َ°ٹ“ {notification} #[fg=$base]î‚°"
                    tab_active_fullscreen   "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} َ°ٹ“ {notification} #[fg=$green]î‚°"
                    tab_normal_sync         "#[bg=$base,fg=$mantle]î‚°#[bg=$base,fg=$overlay0] {index} î‚±#[bg=$base,fg=$overlay0,bold] {name} َ°»† {notification} #[fg=$base]î‚°"
                    tab_active_sync         "#[bg=$green,fg=$mantle]î‚°#[bg=$green,fg=$base] {index} î‚±#[bg=$green,fg=$base,bold,fill] {name} َ°»† {notification} #[fg=$green]î‚°"
                    tab_separator           "#[bg=$mantle,fg=$overlay0]"

                    tab_sync_indicator       "َ°»†"
                    tab_fullscreen_indicator "َ°ٹ“"
                    tab_floating_indicator   "َ°¶™"

                    // Shown when tabs overflow the available rows. {count}
                    // is replaced with the number of hidden tabs.
                    overflow_above "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length 20
                    start_index     1
                    padding_top 0

                    // Right-edge separator between the sidebar and content pane.
                    border "#[fg=$surface1]â”‚"

                    // --- Notifications ---
                    notification_enabled        "true"
                    notification_icon_waiting   "َ°ˆ…"
                    notification_icon_in_progress "َ°‡ک"
                    notification_icon_completed "ï€Œ"
                    notification_format         "#[bg=$surface1,fg=$peach,bold] {count} "
                    notification_show_if_empty  "false"

                    // --- Mode widget ---
                    // Each Zellij mode gets its own accent colour. The `fill`
                    // directive stretches the bg across the row, and {mode_cap}
                    // (in the bottom zone) auto-derives its arrow colour from
                    // whichever mode is active.
                    mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                    mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                    mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                    mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                    mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                    mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                    mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                    mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                    mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                    mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                    mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                    mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "

                    // --- DateTime ---
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"
                }
            }
            pane command="bash"
        }
    }

    // Guide tab â€” opens first so users land here on launch.
    // less shows the guide from the top (scrollable); pressing q
    // drops into a live shell for trying the notification commands.
    // Relative path assumes launch from project root.
    tab name="guide" {
        pane command="bash" {
            args "-c" "less examples/GUIDE.txt; exec bash"
        }
    }

    tab name="tab-1" {
        pane
    }

    tab name="tab-2" {
        pane
        pane
    }

    tab name="tab-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
