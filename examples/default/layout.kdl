// Default example — full-featured horizontal status bar.
//
// Demonstrates:
//   - All widgets: tabs, mode, session, datetime, notifications,
//     swap layout, command (git branch), pipe, cap
//   - Split section pair (left + right in one zone)
//   - Cap widget with auto-colour from fill
//   - format_precedence + format_hide_on_overlength
//   - All tab state variants (normal, active, fullscreen, sync, rename)
//   - Notification system (per-tab icons + global count)

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // -- Catppuccin Mocha palette --
                color_rosewater "#f5e0dc"
                color_flamingo  "#f2cdcd"
                color_pink      "#f5c2e7"
                color_mauve     "#cba6f7"
                color_red       "#f38ba8"
                color_maroon    "#eba0ac"
                color_peach     "#fab387"
                color_yellow    "#f9e2af"
                color_green     "#a6e3a1"
                color_teal      "#94e2d5"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_blue      "#89b4fa"
                color_lavender  "#b4befe"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_subtext0  "#a6adc8"
                color_overlay2  "#9399b2"
                color_overlay1  "#7f849c"
                color_overlay0  "#6c7086"
                color_surface2  "#585b70"
                color_surface1  "#45475a"
                color_surface0  "#313244"
                color_base      "#1e1e2e"
                color_mantle    "#181825"
                color_crust     "#11111b"

                // --- Sections ---
                // format_<index>_<zone> where zone is start/middle/end
                // (aliases: left/center/right also work)
                //
                // Multiple sections in the same zone stack by index order.

                // Left: mode indicator with cap, then tabs
                // The cap widget ({mode_cap}) renders a powerline arrow whose
                // foreground colour is automatically derived from the mode
                // widget's fill background. The cap_bg sets what's "behind" it.
                format_1_left  "{mode}#[fg=$surface1]|{tabs}"
                cap_bg         "$mantle"

                // Right: notification count badge (before session/datetime)
                format_2_right "{notifications}"

                // Right: uses a split section pair — left and right content
                // share the same zone row with a gap between them.
                // Split pairs are defined by giving the same index+zone two
                // keys with _left and _right suffixes.
                format_3_right_left  "#[fg=$subtext0] {pipe_status}{command_git} {session}"
                format_3_right_right "#[fg=$subtext0]{swap_layout} {datetime} "

                // Spacer between zones (the background fill colour).
                format_space "#[bg=$mantle]"

                // When the terminal is too narrow, hide lower-priority zones.
                // Digits are zone indices: 1=left, 2=center, 3=right.
                // "132" means: keep left (1) longest, then right (3), drop center (2) first.
                format_precedence         "132"
                format_hide_on_overlength "true"

                // --- Tab format strings ---
                // Each variant handles a different tab state. Fallback chain:
                //   fullscreen/sync -> active/normal -> tab_normal (hard default)
                tab_normal            "#[fg=$overlay0] {index} {name} #[fg=$overlay0]{notification}"
                tab_active            "#[fg=$base,bg=$green,bold,fill] {index} {name} #[fg=$base,bg=$green]{notification} #[bg=default]"
                tab_normal_fullscreen "#[fg=$overlay0] {index} {name} 󰊓 #[fg=$overlay0]{notification}"
                tab_active_fullscreen "#[fg=$base,bg=$green,bold,fill] {index} {name} 󰊓 #[fg=$base,bg=$green]{notification} #[bg=default]"
                tab_normal_sync       "#[fg=$overlay0] {index} {name}  #[fg=$overlay0]{notification}"
                tab_active_sync       "#[fg=$base,bg=$green,bold,fill] {index} {name}  #[fg=$base,bg=$green]{notification} #[bg=default]"
                tab_rename            "#[fg=$green,italic] {index} {name} "
                tab_separator         "#[fg=$surface1]|"

                max_name_length 18
                start_index     1

                // --- Notifications ---
                // Per-tab: {notification} in tab format strings shows an icon.
                // Global: {notifications} widget shows aggregate count.
                notification_enabled        "true"
                notification_icon_waiting   "⏳"
                notification_icon_in_progress "🔄"
                notification_icon_completed "✅"
                // Per-tab icon formatting by state.
                // This block intentionally applies color to waiting/completed
                // to validate interaction with surrounding tab style segments.
                notification_format_tab         "{icon}"
                notification_format_waiting     "#[fg=$yellow,bold]{icon}"
                notification_format_in_progress "{icon}"
                notification_format_completed   "#[fg=$green,bold]{icon}"
                notification_format         "#[fg=$peach,bold] {count} "
                notification_show_if_empty  "false"

                // --- Mode widget ---
                // The fill directive on the active mode extends its background
                // across the bar and tells the cap widget what colour to use.
                mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "

                // --- DateTime ---
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"

                // --- Swap layout (click to cycle) ---
                swap_layout_format        "#[fg=$overlay0] {name}"
                swap_layout_hide_if_empty "true"

                // --- Command widget: git branch (re-runs every 10s) ---
                // rendermode "static" substitutes {stdout} into the format string.
                // Try "dynamic" to let the command output contain #[style] directives.
                command_git_command    "git branch --show-current"
                command_git_format     "#[fg=$blue] {stdout} "
                command_git_interval   "10"
                command_git_rendermode "static"

                // --- Pipe widget: arbitrary external data ---
                // Send data: zellij pipe --name "zellij-status::pipe::status::ok"
                pipe_status_format "#[fg=$green] {output} "
            }
        }
    }

    // Guide tab — opens first so users land here on launch.
    // less shows the guide from the top (scrollable); pressing q
    // drops into a live shell for trying the notification commands.
    // Relative path assumes launch from project root.
    tab name="guide" {
        pane command="bash" {
            args "-c" "less examples/GUIDE.txt; exec bash"
        }
    }

    tab name="default-1" {
        pane
    }

    tab name="default-2" {
        pane
        pane
    }

    tab name="default-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
