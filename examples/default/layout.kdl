// Default layout for zellij-status â€” new user experience.
// Left sidebar: plugin in vertical tab mode with minimal styling.
// Right area: shell panes (tab content).
//
// Demonstrates all Phase 1-5 features:
//   Sections, tabs, mode, session, datetime, notifications,
//   swap layout, command widget (git branch), pipe widget.

layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=22 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // Minimal colour aliases
                    color_bg      "#1e1e2e"
                    color_fg      "#cdd6f4"
                    color_accent  "#a6e3a1"
                    color_muted   "#6c7086"
                    color_blue    "#89b4fa"

                    // Universal sections (vertical: top / middle / bottom)
                    format_1      "#[fg=$accent,bold] {mode} "
                    format_2      "{tabs}"
                    format_3      "#[fg=$muted] {session} {command_git}{swap_layout}{datetime} "

                    // Tab format strings â€” clean and simple
                    tab_normal          " {index} {name} {notification}"
                    tab_active          "#[fg=$bg,bg=$accent,fill] {index} {name} {notification}"
                    tab_normal_fullscreen " {index} {name} ó°Š“ {notification}"
                    tab_active_fullscreen "#[fg=$bg,bg=$accent,fill] {index} {name} ó°Š“ {notification}"
                    tab_normal_sync     " {index} {name}  {notification}"
                    tab_active_sync     "#[fg=$bg,bg=$accent,fill] {index} {name}  {notification}"
                    tab_rename          "#[fg=$accent,italic] {index} {name} "
                    tab_separator       "#[fg=$muted]â”€"

                    overflow_above      "#[fg=$muted]  ^ +{count}"
                    overflow_below      "#[fg=$muted]  v +{count}"

                    max_name_length     18
                    padding_top         0
                    border              "#[fg=$muted]â”‚"
                    start_index         1

                    // Notifications
                    notification_enabled        "true"
                    notification_waiting_icon   "âŹł"
                    notification_completed_icon "âś…"

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$muted] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 10s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "10"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::ok"
                    pipe_status_format "#[fg=$accent]{output}"
                }
            }
            children
        }
    }

    // Runtime-created tabs (eg. NewTab) use this template.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=22 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // Minimal colour aliases
                    color_bg      "#1e1e2e"
                    color_fg      "#cdd6f4"
                    color_accent  "#a6e3a1"
                    color_muted   "#6c7086"
                    color_blue    "#89b4fa"

                    // Universal sections (vertical: top / middle / bottom)
                    format_1      "#[fg=$accent,bold] {mode} "
                    format_2      "{tabs}"
                    format_3      "#[fg=$muted] {session} {command_git}{swap_layout}{datetime} "

                    // Tab format strings â€” clean and simple
                    tab_normal          " {index} {name} {notification}"
                    tab_active          "#[fg=$bg,bg=$accent,fill] {index} {name} {notification}"
                    tab_normal_fullscreen " {index} {name} ó°Š“ {notification}"
                    tab_active_fullscreen "#[fg=$bg,bg=$accent,fill] {index} {name} ó°Š“ {notification}"
                    tab_normal_sync     " {index} {name}  {notification}"
                    tab_active_sync     "#[fg=$bg,bg=$accent,fill] {index} {name}  {notification}"
                    tab_rename          "#[fg=$accent,italic] {index} {name} "
                    tab_separator       "#[fg=$muted]â”€"

                    overflow_above      "#[fg=$muted]  ^ +{count}"
                    overflow_below      "#[fg=$muted]  v +{count}"

                    max_name_length     18
                    padding_top         0
                    border              "#[fg=$muted]â”‚"
                    start_index         1

                    // Notifications
                    notification_enabled        "true"
                    notification_waiting_icon   "âŹł"
                    notification_completed_icon "âś…"

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$muted] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 10s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "10"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::ok"
                    pipe_status_format "#[fg=$accent]{output}"
                }
            }
            pane command="sh"
        }
    }

    tab name="default-1" {
        pane
    }

    tab name="default-2" {
        pane
        pane
    }

    tab name="default-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
