// Gallery: Horizontal — comparison of horizontal bar styling options.
//
// Demonstrates horizontal-specific features with inline commentary on
// alternatives you can swap in. Resize the terminal narrower to see
// format_precedence + overlength hiding in action.
//
// Demonstrates:
//   - format_space with visible coloured fill
//   - format_precedence + format_hide_on_overlength (resize to see!)
//   - Multiple sections stacked in the right zone (index ordering)
//   - tab_separator styling
//   - {command_NAME} with rendermode "static"
//   - {datetime} with alternative format strings (see comments)
//   - Gruvbox Dark colour scheme

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // -- Gruvbox Dark palette --
                color_bg0     "#282828"
                color_bg1     "#3c3836"
                color_bg2     "#504945"
                color_bg3     "#665c54"
                color_fg0     "#fbf1c7"
                color_fg1     "#ebdbb2"
                color_fg2     "#d5c4a1"
                color_fg3     "#bdae93"
                color_fg4     "#a89984"
                color_red     "#fb4934"
                color_green   "#b8bb26"
                color_yellow  "#fabd2f"
                color_blue    "#83a598"
                color_purple  "#d3869b"
                color_aqua    "#8ec07c"
                color_orange  "#fe8019"
                color_gray    "#928374"

                // --- Left zone: mode + tabs ---
                format_1_left "#[bg=$blue,fg=$bg0,bold,fill]{mode}#[bg=$bg0,fg=$blue]#[bg=$bg0]{tabs}"

                // --- Right zone: notifications (first item) ---
                format_2_right "{notifications}"

                // --- Right zone: stacked sections ---
                // Multiple sections in the same zone render in index order.
                // Section 3: session name
                format_3_right "#[fg=$fg4] {session} "
                // Section 4: git branch
                format_4_right "#[bg=$bg0,fg=$bg2]#[bg=$bg2,fg=$fg1] {command_git}"
                // Section 5: datetime
                format_5_right "#[bg=$bg2,fg=$fg4]#[bg=$fg4,fg=$bg0,bold] {datetime} "

                // --- Spacer ---
                // format_space styles the gap between zones.
                // Try different bg colours to make the spacer visible or subtle:
                //   Visible:  "#[bg=$bg1]"
                //   Subtle:   "#[bg=$bg0]"
                //   Dotted:   "#[fg=$bg2,bg=$bg0]·"
                format_space "#[bg=$bg0]"

                // --- Overlength hiding ---
                // format_precedence sets zone priority when content exceeds
                // terminal width. Digits map to zone indices:
                //   1=left, 2=center, 3=right
                // "132" = keep left longest, then right, drop center first.
                // Resize your terminal narrower to see zones disappear!
                format_precedence         "132"
                format_hide_on_overlength "true"

                // --- Tab format strings ---
                tab_normal          "#[fg=$fg4] {index}:{name} {notification}"
                tab_active          "#[fg=$bg0,bg=$green,bold] {index}:{name} {notification} #[bg=default]"
                tab_normal_fullscreen "#[fg=$fg4] {index}:{name} 󰊓 {notification}"
                tab_active_fullscreen "#[fg=$bg0,bg=$green,bold] {index}:{name} 󰊓 {notification} #[bg=default]"
                tab_normal_sync     "#[fg=$fg4] {index}:{name}  {notification}"
                tab_active_sync     "#[fg=$bg0,bg=$green,bold] {index}:{name}  {notification} #[bg=default]"
                tab_rename          "#[fg=$green,italic] {index}:{name} "

                // tab_separator renders between each tab in horizontal mode.
                // Try different styles:
                //   Pipe:    "#[fg=$bg2]|"
                //   Slash:   "#[fg=$bg2]/"
                //   Dot:     "#[fg=$bg2]·"
                //   Arrow:   "#[fg=$bg2]>"
                //   Empty:   "" (tabs touch directly)
                tab_separator "#[fg=$bg2]│"

                max_name_length 16
                start_index     1

                // --- Notifications ---
                notification_enabled        "true"
                notification_waiting_icon   "⏳"
                notification_completed_icon "✅"
                notification_format         "#[fg=$orange,bold] {count} "
                notification_show_if_empty  "false"

                // --- Mode widget ---
                mode_normal       " NORMAL "
                mode_locked       " LOCKED "
                mode_pane         " PANE "
                mode_rename_pane  " RENAMEPANE "
                mode_tab          " TAB "
                mode_rename_tab   " RENAMETAB "
                mode_scroll       " SCROLL "
                mode_enter_search " ENT-SEARCH "
                mode_search       " SEARCH "
                mode_resize       " RESIZE "
                mode_move         " MOVE "
                mode_session      " SESSION "
                mode_tmux         " TMUX "
                mode_prompt       " PROMPT "

                // --- DateTime ---
                // Try different format strings:
                //   Time only:      "%H:%M"
                //   Date + time:    "%Y-%m-%d %H:%M"
                //   Day name:       "%a %H:%M"
                //   Full:           "%a %b %d %H:%M"
                datetime_format   "%a %H:%M"
                datetime_timezone "America/Los_Angeles"

                // --- Command widget: git branch ---
                // rendermode "static" substitutes {stdout} into format string.
                // Try "dynamic" to let the command output contain #[style] directives.
                // Try "raw" for unprocessed output.
                command_git_command    "git branch --show-current"
                command_git_format     " {stdout} "
                command_git_interval   "10"
                command_git_rendermode "static"
            }
        }
    }

    new_tab_template {
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"
                color_bg0     "#282828"
                color_bg1     "#3c3836"
                color_bg2     "#504945"
                color_bg3     "#665c54"
                color_fg0     "#fbf1c7"
                color_fg1     "#ebdbb2"
                color_fg2     "#d5c4a1"
                color_fg3     "#bdae93"
                color_fg4     "#a89984"
                color_red     "#fb4934"
                color_green   "#b8bb26"
                color_yellow  "#fabd2f"
                color_blue    "#83a598"
                color_purple  "#d3869b"
                color_aqua    "#8ec07c"
                color_orange  "#fe8019"
                color_gray    "#928374"
                format_1_left "#[bg=$blue,fg=$bg0,bold,fill]{mode}#[bg=$bg0,fg=$blue]#[bg=$bg0]{tabs}"
                format_2_right "{notifications}"
                format_3_right "#[fg=$fg4] {session} "
                format_4_right "#[bg=$bg0,fg=$bg2]#[bg=$bg2,fg=$fg1] {command_git}"
                format_5_right "#[bg=$bg2,fg=$fg4]#[bg=$fg4,fg=$bg0,bold] {datetime} "
                format_space "#[bg=$bg0]"
                format_precedence         "132"
                format_hide_on_overlength "true"
                tab_normal          "#[fg=$fg4] {index}:{name} {notification}"
                tab_active          "#[fg=$bg0,bg=$green,bold] {index}:{name} {notification} #[bg=default]"
                tab_normal_fullscreen "#[fg=$fg4] {index}:{name} 󰊓 {notification}"
                tab_active_fullscreen "#[fg=$bg0,bg=$green,bold] {index}:{name} 󰊓 {notification} #[bg=default]"
                tab_normal_sync     "#[fg=$fg4] {index}:{name}  {notification}"
                tab_active_sync     "#[fg=$bg0,bg=$green,bold] {index}:{name}  {notification} #[bg=default]"
                tab_rename          "#[fg=$green,italic] {index}:{name} "
                tab_separator "#[fg=$bg2]│"
                max_name_length 16
                start_index     1
                notification_enabled        "true"
                notification_waiting_icon   "⏳"
                notification_completed_icon "✅"
                notification_format         "#[fg=$orange,bold] {count} "
                notification_show_if_empty  "false"
                mode_normal       " NORMAL "
                mode_locked       " LOCKED "
                mode_pane         " PANE "
                mode_rename_pane  " RENAMEPANE "
                mode_tab          " TAB "
                mode_rename_tab   " RENAMETAB "
                mode_scroll       " SCROLL "
                mode_enter_search " ENT-SEARCH "
                mode_search       " SEARCH "
                mode_resize       " RESIZE "
                mode_move         " MOVE "
                mode_session      " SESSION "
                mode_tmux         " TMUX "
                mode_prompt       " PROMPT "
                datetime_format   "%a %H:%M"
                datetime_timezone "America/Los_Angeles"
                command_git_command    "git branch --show-current"
                command_git_format     " {stdout} "
                command_git_interval   "10"
                command_git_rendermode "static"
            }
        }
    }

    tab name="tab-1" {
        pane
    }

    tab name="tab-2" {
        pane
        pane
    }

    tab name="tab-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
