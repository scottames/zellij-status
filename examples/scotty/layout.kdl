// Scotty's layout for zellij-status — Catppuccin Mocha with depth.
// Left sidebar: plugin in vertical tab mode with full colour palette.
// Replaces zjstatus (bottom bar) + zellij-attention (notifications).
//
// Demonstrates all Phase 1-5 features:
//   Sections, tabs, mode, session, datetime, notifications,
//   swap layout, command widget (git branch), pipe widget.

layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=28 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Catppuccin Mocha palette --
                    color_rosewater "#f5e0dc"
                    color_flamingo  "#f2cdcd"
                    color_pink      "#f5c2e7"
                    color_mauve     "#cba6f7"
                    color_red       "#f38ba8"
                    color_maroon    "#eba0ac"
                    color_peach     "#fab387"
                    color_yellow    "#f9e2af"
                    color_green     "#a6e3a1"
                    color_teal      "#94e2d5"
                    color_sky       "#89dceb"
                    color_sapphire  "#74c7ec"
                    color_blue      "#89b4fa"
                    color_lavender  "#b4befe"
                    color_text      "#cdd6f4"
                    color_subtext1  "#bac2de"
                    color_subtext0  "#a6adc8"
                    color_overlay2  "#9399b2"
                    color_overlay1  "#7f849c"
                    color_overlay0  "#6c7086"
                    color_surface2  "#585b70"
                    color_surface1  "#45475a"
                    color_surface0  "#313244"
                    color_base      "#1e1e2e"
                    color_mantle    "#181825"
                    color_crust     "#11111b"

                    // Universal sections (vertical: top / middle / bottom)
                    // TODO: support moving mode to bottom
                    // TODO: support more "formats", possibly an array of them
                    format_1                "{mode}"
                    format_2                "{tabs}"
                    format_3                "#[fg=$overlay0] {session} #[fg=$subtext0]{datetime} "

                    // Tab format strings - powerline-inspired, stacked vertically
                    tab_normal              "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} {notification}"
                    tab_active              "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name} {notification}"
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} 󰊓 {notification}"
                    tab_active_fullscreen   "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name} 󰊓 {notification}"
                    tab_normal_sync         "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name}  {notification}"
                    tab_active_sync         "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name}  {notification}"
                    tab_rename              "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold] RENAME #[bg=$mantle,fg=$green]"
                    tab_separator           "#[fg=$surface1,bg=$mantle]─"

                    overflow_above          "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below          "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length         20
                    padding_top             0
                    border                  "#[fg=$surface1]│"
                    start_index             1

                    // Notifications (replacing zellij-attention icons)
                    notification_enabled        "true"
                    notification_waiting_icon   ""
                    notification_completed_icon ""

                    // Mode widget (global zjstatus-inspired powerline)
                    mode_normal       "#[bg=$blue,fg=$base,bold] NORMAL #[bg=$base,fg=$blue]"
                    mode_locked       "#[bg=$red,fg=$base,bold] LOCKED #[bg=$base,fg=$red]"
                    mode_pane         "#[bg=$peach,fg=$base,bold] PANE #[bg=$base,fg=$peach]"
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold] RENAMEPANE #[bg=$base,fg=$peach]"
                    mode_tab          "#[bg=$green,fg=$base,bold] TAB #[bg=$base,fg=$green]"
                    mode_rename_tab   "#[bg=$green,fg=$base,bold] RENAMETAB #[bg=$base,fg=$green]"
                    mode_scroll       "#[bg=$peach,fg=$base,bold] SCROLL #[bg=$base,fg=$peach]"
                    mode_enter_search "#[bg=$yellow,fg=$base,bold] ENT-SEARCH #[bg=$base,fg=$yellow]"
                    mode_search       "#[bg=$yellow,fg=$base,bold] SEARCH #[bg=$base,fg=$yellow]"
                    mode_resize       "#[bg=$teal,fg=$base,bold] RESIZE #[bg=$base,fg=$teal]"
                    mode_move         "#[bg=$teal,fg=$base,bold] MOVE #[bg=$base,fg=$teal]"
                    mode_session      "#[bg=$mauve,fg=$base,bold] SESSION #[bg=$base,fg=$mauve]"
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold] TMUX #[bg=$base,fg=$flamingo]"
                    mode_prompt       "#[bg=$red,fg=$peach,bold] PROMPT #[bg=$base,fg=$red]"
                    //TODO: mode_alignment | left (default, or right)

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$overlay0] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 5s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "5"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::running"
                    pipe_status_format "#[fg=$green]{output} "
                }
            }
            children
        }
    }

    // Runtime-created tabs (eg. NewTab) use this template.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=28 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Catppuccin Mocha palette --
                    color_rosewater "#f5e0dc"
                    color_flamingo  "#f2cdcd"
                    color_pink      "#f5c2e7"
                    color_mauve     "#cba6f7"
                    color_red       "#f38ba8"
                    color_maroon    "#eba0ac"
                    color_peach     "#fab387"
                    color_yellow    "#f9e2af"
                    color_green     "#a6e3a1"
                    color_teal      "#94e2d5"
                    color_sky       "#89dceb"
                    color_sapphire  "#74c7ec"
                    color_blue      "#89b4fa"
                    color_lavender  "#b4befe"
                    color_text      "#cdd6f4"
                    color_subtext1  "#bac2de"
                    color_subtext0  "#a6adc8"
                    color_overlay2  "#9399b2"
                    color_overlay1  "#7f849c"
                    color_overlay0  "#6c7086"
                    color_surface2  "#585b70"
                    color_surface1  "#45475a"
                    color_surface0  "#313244"
                    color_base      "#1e1e2e"
                    color_mantle    "#181825"
                    color_crust     "#11111b"

                    // Universal sections (vertical: top / middle / bottom)
                    format_1                "{mode}"
                    format_2                "{tabs}"
                    format_3                "#[fg=$overlay0] {session} #[fg=$subtext0]{datetime} "

                    // Tab format strings - powerline-inspired, stacked vertically
                    tab_normal              "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} {notification}"
                    tab_active              "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name} {notification}"
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} 󰊓 {notification}"
                    tab_active_fullscreen   "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name} 󰊓 {notification}"
                    tab_normal_sync         "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name}  {notification}"
                    tab_active_sync         "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold,fill] {name}  {notification}"
                    tab_rename              "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold] RENAME #[bg=$mantle,fg=$green]"
                    tab_separator           "#[fg=$surface1,bg=$mantle]─"

                    overflow_above          "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below          "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length         20
                    padding_top             0
                    border                  "#[fg=$surface1]│"
                    start_index             1

                    // Notifications (replacing zellij-attention icons)
                    notification_enabled        "true"
                    notification_waiting_icon   ""
                    notification_completed_icon ""

                    // Mode widget (global zjstatus-inspired powerline)
                    mode_normal       "#[bg=$blue,fg=$base,bold] NORMAL #[bg=$base,fg=$blue]"
                    mode_locked       "#[bg=$red,fg=$base,bold] LOCKED #[bg=$base,fg=$red]"
                    mode_pane         "#[bg=$peach,fg=$base,bold] PANE #[bg=$base,fg=$peach]"
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold] RENAMEPANE #[bg=$base,fg=$peach]"
                    mode_tab          "#[bg=$green,fg=$base,bold] TAB #[bg=$base,fg=$green]"
                    mode_rename_tab   "#[bg=$green,fg=$base,bold] RENAMETAB #[bg=$base,fg=$green]"
                    mode_scroll       "#[bg=$peach,fg=$base,bold] SCROLL #[bg=$base,fg=$peach]"
                    mode_enter_search "#[bg=$yellow,fg=$base,bold] ENT-SEARCH #[bg=$base,fg=$yellow]"
                    mode_search       "#[bg=$yellow,fg=$base,bold] SEARCH #[bg=$base,fg=$yellow]"
                    mode_resize       "#[bg=$teal,fg=$base,bold] RESIZE #[bg=$base,fg=$teal]"
                    mode_move         "#[bg=$teal,fg=$base,bold] MOVE #[bg=$base,fg=$teal]"
                    mode_session      "#[bg=$mauve,fg=$base,bold] SESSION #[bg=$base,fg=$mauve]"
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold] TMUX #[bg=$base,fg=$flamingo]"
                    mode_prompt       "#[bg=$red,fg=$peach,bold] PROMPT #[bg=$base,fg=$red]"

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$overlay0] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 5s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "5"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::running"
                    pipe_status_format "#[fg=$green]{output} "
                }
            }
            pane command="fish"
        }
    }

    tab name="~" {
        pane
    }

    tab name="dev" {
        pane
        pane
    }

    tab name="split" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
