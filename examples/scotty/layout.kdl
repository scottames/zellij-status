// Scotty's layout for zellij-status — Catppuccin Mocha with depth.
// Left sidebar: plugin in vertical tab mode with full colour palette.
// Replaces zjstatus (bottom bar) + zellij-attention (notifications).
//
// Demonstrates all Phase 1-5 features:
//   Sections, tabs, mode, session, datetime, notifications,
//   swap layout, command widget (git branch), pipe widget.

layout {
    default_tab_template {
        pane split_direction="vertical" {
            pane size=28 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Catppuccin Mocha palette --
                    color_rosewater "#f5e0dc"
                    color_flamingo  "#f2cdcd"
                    color_pink      "#f5c2e7"
                    color_mauve     "#cba6f7"
                    color_red       "#f38ba8"
                    color_maroon    "#eba0ac"
                    color_peach     "#fab387"
                    color_yellow    "#f9e2af"
                    color_green     "#a6e3a1"
                    color_teal      "#94e2d5"
                    color_sky       "#89dceb"
                    color_sapphire  "#74c7ec"
                    color_blue      "#89b4fa"
                    color_lavender  "#b4befe"
                    color_text      "#cdd6f4"
                    color_subtext1  "#bac2de"
                    color_subtext0  "#a6adc8"
                    color_overlay2  "#9399b2"
                    color_overlay1  "#7f849c"
                    color_overlay0  "#6c7086"
                    color_surface2  "#585b70"
                    color_surface1  "#45475a"
                    color_surface0  "#313244"
                    color_base      "#1e1e2e"
                    color_mantle    "#181825"
                    color_crust     "#11111b"

                    // Universal sections (zone semantics)
                    // start = top in vertical mode
                    // middle = vertical middle
                    // end = bottom in vertical mode
                    format_1_middle_right         "{tabs}"
                    format_3_bottom_center  "#[fg=$overlay0] {session}"
                    format_2_bottom_left    "{mode}"
                    format_2_bottom_right   "{mode_cap}"
                    format_4_bottom_left    "{datetime_cap}"
                    format_4_bottom_right   "#[bg=$surface1,fg=$base,bold,fill] {datetime} "
                    format_1_bottom_left    "{tabs_cap}"
                    format_1_bottom_right   "#[fg=$overlay1] active tab"

                    // Generic cap controls for `{widget}_cap`
                    cap_bg                 "$base"
                    datetime_cap_fg        "$surface1"
                    datetime_cap_symbol    ""

                    // More cap patterns you can try:
                    // - no fill, plain text:
                    //   format_5_bottom_left  "{session_cap}"
                    //   format_5_bottom_right "#[fg=$overlay0]{session}"
                    //   session_cap_fg        "$overlay0"
                    // - short custom symbol:
                    //   mode_cap_symbol       "▶"
                    // - dynamic tabs-based cap sample (already enabled above):
                    //   format_1_bottom_left  "{tabs_cap}"
                    //   format_1_bottom_right "#[fg=$overlay1] active tab"

                    // Tab format strings - powerline-inspired, stacked vertically
                    tab_normal              "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} {notification}"
                    tab_active              "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name} {notification} "
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} 󰊓 {notification}"
                    tab_active_fullscreen   "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name} 󰊓 {notification} "
                    tab_normal_sync         "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name}  {notification}"
                    tab_active_sync         "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name}  {notification} "
                    tab_rename              "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] RENAME "
                    tab_separator           "#[fg=$surface1,bg=$mantle]─"

                    overflow_above          "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below          "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length         20
                    padding_top             0
                    border                  "#[fg=$surface1]│"
                    start_index             1

                    // Notifications (replacing zellij-attention icons)
                    notification_enabled        "true"
                    notification_waiting_icon   ""
                    notification_completed_icon ""

                    // Mode widget (global zjstatus-inspired powerline)
                    mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                    mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                    mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                    mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                    mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                    mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                    mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                    mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                    mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                    mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                    mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                    mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "
                    //TODO: mode_alignment | left (default, or right)

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$overlay0] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 5s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "5"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::running"
                    pipe_status_format "#[fg=$green]{output} "
                }
            }
            children
        }
    }

    // Runtime-created tabs (eg. NewTab) use this template.
    new_tab_template {
        pane split_direction="vertical" {
            pane size=28 borderless=true {
                plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                    layout_mode "vertical"

                    // -- Catppuccin Mocha palette --
                    color_rosewater "#f5e0dc"
                    color_flamingo  "#f2cdcd"
                    color_pink      "#f5c2e7"
                    color_mauve     "#cba6f7"
                    color_red       "#f38ba8"
                    color_maroon    "#eba0ac"
                    color_peach     "#fab387"
                    color_yellow    "#f9e2af"
                    color_green     "#a6e3a1"
                    color_teal      "#94e2d5"
                    color_sky       "#89dceb"
                    color_sapphire  "#74c7ec"
                    color_blue      "#89b4fa"
                    color_lavender  "#b4befe"
                    color_text      "#cdd6f4"
                    color_subtext1  "#bac2de"
                    color_subtext0  "#a6adc8"
                    color_overlay2  "#9399b2"
                    color_overlay1  "#7f849c"
                    color_overlay0  "#6c7086"
                    color_surface2  "#585b70"
                    color_surface1  "#45475a"
                    color_surface0  "#313244"
                    color_base      "#1e1e2e"
                    color_mantle    "#181825"
                    color_crust     "#11111b"

                    // Universal sections (zone semantics)
                    // start = top in vertical mode
                    // middle = vertical middle
                    // end = bottom in vertical mode
                    format_1_middle_right   "{tabs}"
                    format_3_bottom_center  "#[fg=$overlay0] {session}"
                    format_2_bottom_left    "{mode}"
                    format_2_bottom_right   "{mode_cap}"
                    format_4_bottom_left    "{datetime_cap}"
                    format_4_bottom_right   "#[bg=$surface1,fg=$base,bold,fill] {datetime} "
                    format_1_bottom_left    "{tabs_cap}"
                    format_1_bottom_right   "#[fg=$overlay1] active tab"

                    // Generic cap controls for `{widget}_cap`
                    cap_bg                 "$base"
                    datetime_cap_fg        "$surface1"
                    datetime_cap_symbol    ""

                    // More cap patterns you can try:
                    // - no fill, plain text:
                    //   format_5_bottom_left  "{session_cap}"
                    //   format_5_bottom_right "#[fg=$overlay0]{session}"
                    //   session_cap_fg        "$overlay0"
                    // - short custom symbol:
                    //   mode_cap_symbol       "▶"
                    // - dynamic tabs-based cap sample (already enabled above):
                    //   format_1_bottom_left  "{tabs_cap}"
                    //   format_1_bottom_right "#[fg=$overlay1] active tab"

                    // Tab format strings - powerline-inspired, stacked vertically
                    tab_normal              "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} {notification}"
                    tab_active              "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name} {notification} "
                    tab_normal_fullscreen   "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} 󰊓 {notification}"
                    tab_active_fullscreen   "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name} 󰊓 {notification} "
                    tab_normal_sync         "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name}  {notification}"
                    tab_active_sync         "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] {index} {name}  {notification} "
                    tab_rename              "#[bg=$base,fg=$green]#[bg=$green,fg=$base,bold,fill] RENAME "
                    tab_separator           "#[fg=$surface1,bg=$mantle]─"

                    overflow_above          "#[fg=$overlay0,bg=$mantle]  ^ +{count}"
                    overflow_below          "#[fg=$overlay0,bg=$mantle]  v +{count}"

                    max_name_length         20
                    padding_top             0
                    border                  "#[fg=$surface1]│"
                    start_index             1

                    // Notifications (replacing zellij-attention icons)
                    notification_enabled        "true"
                    notification_waiting_icon   ""
                    notification_completed_icon ""

                    // Mode widget (global zjstatus-inspired powerline)
                    mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                    mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                    mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                    mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                    mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                    mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                    mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                    mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                    mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                    mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                    mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                    mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                    mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                    mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "

                    // DateTime widget
                    datetime_format   "%H:%M"
                    datetime_timezone "America/Los_Angeles"

                    // Swap layout widget (click to cycle layouts)
                    swap_layout_format        "#[fg=$overlay0] {name}"
                    swap_layout_hide_if_empty "true"

                    // Command widget: show current git branch (re-runs every 5s)
                    command_git_command    "git branch --show-current"
                    command_git_format     "#[fg=$blue] {stdout} "
                    command_git_interval   "5"
                    command_git_rendermode "static"

                    // Pipe widget: display arbitrary data sent via pipe
                    // Usage: zellij pipe --name "zellij-status::pipe::status::running"
                    pipe_status_format "#[fg=$green]{output} "
                }
            }
            pane command="fish"
        }
    }

    tab name="~" {
        pane
    }

    tab name="dev" {
        pane
        pane
    }

    tab name="split" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
