// Horizontal bar layout tuned to match Scotty's global zjstatus styling.
// Plugin renders as a single-row status bar at the bottom.
// Sections: format_1=left, format_2=center, format_3=right.

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // -- Catppuccin Mocha --
                color_rosewater "#f5e0dc"
                color_flamingo  "#f2cdcd"
                color_pink      "#f5c2e7"
                color_mauve     "#cba6f7"
                color_red       "#f38ba8"
                color_maroon    "#eba0ac"
                color_peach     "#fab387"
                color_yellow    "#f9e2af"
                color_green     "#a6e3a1"
                color_teal      "#94e2d5"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_blue      "#89b4fa"
                color_lavender  "#b4befe"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_subtext0  "#a6adc8"
                color_overlay2  "#9399b2"
                color_overlay1  "#7f849c"
                color_overlay0  "#6c7086"
                color_surface2  "#585b70"
                color_surface1  "#45475a"
                color_surface0  "#313244"
                color_base      "#1e1e2e"
                color_mantle    "#181825"
                color_crust     "#11111b"

                // Sections: left / center / right
                format_1      "#[bg=$base,fg=$overlay2]{mode}#[bg=$mantle]{tabs}"
                format_2      "{notifications}"
                format_3      "#[bg=$mantle,fg=$base]#[bg=$base,fg=$subtext0] {session} #[bg=$base,fg=$overlay2]#[bg=$overlay2,fg=$mantle] {datetime} "
                format_space  "#[bg=$mantle,fg=$overlay0]"
                format_precedence       "132"
                format_hide_on_overlength "true"

                // Inline tab format strings (horizontal: tabs render inline)
                tab_normal            "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} {notification}#[bg=$mantle,fg=$base]"
                tab_normal_fullscreen "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name} 󰊓 {notification}#[bg=$mantle,fg=$base]"
                tab_normal_sync       "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} #[bg=$base,fg=$overlay0,bold] {name}  {notification}#[bg=$mantle,fg=$base]"
                tab_active            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold] {name} {notification}#[bg=$mantle,fg=$green]"
                tab_active_fullscreen "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold] {name} 󰊓 {notification}#[bg=$mantle,fg=$green]"
                tab_active_sync       "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base] {index} #[bg=$green,fg=$base,bold] {name}  {notification}#[bg=$mantle,fg=$green]"
                tab_rename            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold] RENAME #[bg=$mantle,fg=$green]"
                tab_separator         "#[bg=$mantle,fg=$overlay0]"

                // Notifications (inline with tab names + center count)
                notification_enabled        "true"
                notification_waiting_icon   ""
                notification_completed_icon ""
                notification_format         "#[bg=$peach,fg=$mantle]#[bg=$peach,fg=$mantle] {count} #[bg=$mantle,fg=$peach]"
                notification_show_if_empty  "false"

                // Mode widget — per-mode colours
                mode_normal       "#[bg=$base,fg=$base]#[bg=$blue,fg=$base,bold] NORMAL #[bg=$base,fg=$blue]"
                mode_locked       "#[bg=$base,fg=$base]#[bg=$red,fg=$base,bold] LOCKED #[bg=$base,fg=$red]"
                mode_pane         "#[bg=$base,fg=$base]#[bg=$peach,fg=$base,bold] PANE #[bg=$base,fg=$peach]"
                mode_rename_pane  "#[bg=$base,fg=$base]#[bg=$peach,fg=$base,bold] RENAMEPANE #[bg=$base,fg=$peach]"
                mode_tab          "#[bg=$base,fg=$base]#[bg=$green,fg=$base,bold] TAB #[bg=$base,fg=$green]"
                mode_rename_tab   "#[bg=$base,fg=$base]#[bg=$green,fg=$base,bold] RENAMETAB #[bg=$base,fg=$green]"
                mode_scroll       "#[bg=$base,fg=$base]#[bg=$peach,fg=$base,bold] SCROLL #[bg=$base,fg=$peach]"
                mode_enter_search "#[bg=$base,fg=$base]#[bg=$yellow,fg=$base,bold] ENT-SEARCH #[bg=$base,fg=$yellow]"
                mode_search       "#[bg=$base,fg=$base]#[bg=$yellow,fg=$base,bold] SEARCH #[bg=$base,fg=$yellow]"
                mode_resize       "#[bg=$base,fg=$base]#[bg=$teal,fg=$base,bold] RESIZE #[bg=$base,fg=$teal]"
                mode_move         "#[bg=$base,fg=$base]#[bg=$teal,fg=$base,bold] MOVE #[bg=$base,fg=$teal]"
                mode_session      "#[bg=$base,fg=$base]#[bg=$mauve,fg=$base,bold] SESSION #[bg=$base,fg=$mauve]"
                mode_tmux         "#[bg=$base,fg=$base]#[bg=$flamingo,fg=$base,bold] TMUX #[bg=$base,fg=$flamingo]"
                mode_prompt       "#[bg=$base,fg=$base]#[bg=$red,fg=$peach,bold] PROMPT #[bg=$base,fg=$red]"

                // DateTime widget
                datetime_format   "%Y-%m-%d %H:%M"
                datetime_timezone "America/Los_Angeles"

                // Swap layout widget
                swap_layout_format        "#[fg=$overlay0]{name} "
                swap_layout_hide_if_empty "true"

                // No extra dynamic widgets here - keep parity with global zjstatus feel.
            }
        }
    }

    tab name="horizontal-1" {
        pane
    }

    tab name="horizontal-2" {
        pane
        pane
    }

    tab name="horizontal-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
