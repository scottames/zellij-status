// Powerline example — styled horizontal bar with caps in both directions.
//
// Demonstrates:
//   - Powerline glyphs: left zone caps point right (), right zone caps
//     point left () — arrows flow "into" the bar from each edge
//   - {widget_cap} with auto-colour derived from fill directive
//   - cap_bg (global) and per-widget cap overrides
//   - fill directive on mode + active tab for row background extension
//   - Full 14-mode per-mode colours
//   - Notifications with styled powerline pill
//   - format_precedence + overlength hiding

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // -- Catppuccin Mocha palette --
                color_rosewater "#f5e0dc"
                color_flamingo  "#f2cdcd"
                color_pink      "#f5c2e7"
                color_mauve     "#cba6f7"
                color_red       "#f38ba8"
                color_maroon    "#eba0ac"
                color_peach     "#fab387"
                color_yellow    "#f9e2af"
                color_green     "#a6e3a1"
                color_teal      "#94e2d5"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_blue      "#89b4fa"
                color_lavender  "#b4befe"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_subtext0  "#a6adc8"
                color_overlay2  "#9399b2"
                color_overlay1  "#7f849c"
                color_overlay0  "#6c7086"
                color_surface2  "#585b70"
                color_surface1  "#45475a"
                color_surface0  "#313244"
                color_base      "#1e1e2e"
                color_mantle    "#181825"
                color_crust     "#11111b"

                // --- Left zone: mode pill + cap pointing right, then tabs ---
                // The  glyph points right — caps on the left edge flow INTO the bar.
                // {mode_cap} auto-derives its fg from mode's fill bg colour.
                format_1_left "{mode}{mode_cap}{tabs}"

                // --- Center zone: notification count ---
                format_2_center "{notifications}"

                // --- Right zone: caps pointing left, then widgets ---
                // The  glyph points left — caps on the right edge flow INTO the bar.
                // Stacking two sections in the right zone (index 3 and 4)
                // renders them in order: session first, datetime after.
                format_3_right "#[bg=$mantle,fg=$base]#[bg=$base,fg=$subtext0] {session} "
                format_4_right "#[bg=$base,fg=$surface1]#[bg=$surface1,fg=$text] {datetime} "

                // Cap config: background behind all cap arrows.
                cap_bg "$mantle"

                // Spacer fill between zones.
                format_space "#[bg=$mantle]"

                // Zone priority for narrow terminals:
                // 1=left (keep longest), 3=right, 2=center (drop first).
                format_precedence         "132"
                format_hide_on_overlength "true"

                // --- Tab format strings ---
                // Powerline arrows baked into tab format strings:
                //  before the tab (left edge),  after (right edge).
                // Active tab uses fill for powerline colour propagation.
                tab_normal            "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} {notification}#[bg=$mantle,fg=$base]"
                tab_active            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name} {notification} #[bg=$mantle,fg=$green]"
                tab_normal_fullscreen "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} 󰊓 {notification}#[bg=$mantle,fg=$base]"
                tab_active_fullscreen "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name} 󰊓 {notification} #[bg=$mantle,fg=$green]"
                tab_normal_sync       "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name}  {notification}#[bg=$mantle,fg=$base]"
                tab_active_sync       "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name}  {notification} #[bg=$mantle,fg=$green]"
                tab_rename            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] RENAME #[bg=$mantle,fg=$green]"
                tab_separator         ""

                max_name_length 18
                start_index     1

                // --- Notifications ---
                notification_enabled        "true"
                notification_waiting_icon   ""
                notification_completed_icon ""
                // Styled as a powerline pill in the center zone.
                notification_format         "#[bg=$peach,fg=$mantle]#[bg=$peach,fg=$mantle,bold] {count} #[bg=$mantle,fg=$peach]"
                notification_show_if_empty  "false"

                // --- Mode widget ---
                // fill makes mode's bg extend and tells {mode_cap} what colour
                // to use for its arrow glyph.
                mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "

                // --- DateTime ---
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"

                // --- Swap layout ---
                swap_layout_format        "#[fg=$overlay0]{name} "
                swap_layout_hide_if_empty "true"
            }
        }
    }

    new_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"
                color_rosewater "#f5e0dc"
                color_flamingo  "#f2cdcd"
                color_pink      "#f5c2e7"
                color_mauve     "#cba6f7"
                color_red       "#f38ba8"
                color_maroon    "#eba0ac"
                color_peach     "#fab387"
                color_yellow    "#f9e2af"
                color_green     "#a6e3a1"
                color_teal      "#94e2d5"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_blue      "#89b4fa"
                color_lavender  "#b4befe"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_subtext0  "#a6adc8"
                color_overlay2  "#9399b2"
                color_overlay1  "#7f849c"
                color_overlay0  "#6c7086"
                color_surface2  "#585b70"
                color_surface1  "#45475a"
                color_surface0  "#313244"
                color_base      "#1e1e2e"
                color_mantle    "#181825"
                color_crust     "#11111b"
                format_1_left "{mode}{mode_cap}{tabs}"
                format_2_center "{notifications}"
                format_3_right "#[bg=$mantle,fg=$base]#[bg=$base,fg=$subtext0] {session} "
                format_4_right "#[bg=$base,fg=$surface1]#[bg=$surface1,fg=$text] {datetime} "
                cap_bg "$mantle"
                format_space "#[bg=$mantle]"
                format_precedence         "132"
                format_hide_on_overlength "true"
                tab_normal            "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} {notification}#[bg=$mantle,fg=$base]"
                tab_active            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name} {notification} #[bg=$mantle,fg=$green]"
                tab_normal_fullscreen "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name} 󰊓 {notification}#[bg=$mantle,fg=$base]"
                tab_active_fullscreen "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name} 󰊓 {notification} #[bg=$mantle,fg=$green]"
                tab_normal_sync       "#[bg=$base,fg=$mantle]#[bg=$base,fg=$overlay0] {index} {name}  {notification}#[bg=$mantle,fg=$base]"
                tab_active_sync       "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] {index} {name}  {notification} #[bg=$mantle,fg=$green]"
                tab_rename            "#[bg=$green,fg=$mantle]#[bg=$green,fg=$base,bold,fill] RENAME #[bg=$mantle,fg=$green]"
                tab_separator         ""
                max_name_length 18
                start_index     1
                notification_enabled        "true"
                notification_waiting_icon   ""
                notification_completed_icon ""
                notification_format         "#[bg=$peach,fg=$mantle]#[bg=$peach,fg=$mantle,bold] {count} #[bg=$mantle,fg=$peach]"
                notification_show_if_empty  "false"
                mode_normal       "#[bg=$blue,fg=$base,bold,fill] NORMAL "
                mode_locked       "#[bg=$red,fg=$base,bold,fill] LOCKED "
                mode_pane         "#[bg=$peach,fg=$base,bold,fill] PANE "
                mode_rename_pane  "#[bg=$peach,fg=$base,bold,fill] RENAMEPANE "
                mode_tab          "#[bg=$green,fg=$base,bold,fill] TAB "
                mode_rename_tab   "#[bg=$green,fg=$base,bold,fill] RENAMETAB "
                mode_scroll       "#[bg=$peach,fg=$base,bold,fill] SCROLL "
                mode_enter_search "#[bg=$yellow,fg=$base,bold,fill] ENT-SEARCH "
                mode_search       "#[bg=$yellow,fg=$base,bold,fill] SEARCH "
                mode_resize       "#[bg=$teal,fg=$base,bold,fill] RESIZE "
                mode_move         "#[bg=$teal,fg=$base,bold,fill] MOVE "
                mode_session      "#[bg=$mauve,fg=$base,bold,fill] SESSION "
                mode_tmux         "#[bg=$flamingo,fg=$base,bold,fill] TMUX "
                mode_prompt       "#[bg=$red,fg=$peach,bold,fill] PROMPT "
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"
                swap_layout_format        "#[fg=$overlay0]{name} "
                swap_layout_hide_if_empty "true"
            }
        }
    }

    tab name="powerline-1" {
        pane
    }

    tab name="powerline-2" {
        pane
        pane
    }

    tab name="powerline-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
