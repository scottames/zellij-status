// Powerline example — styled horizontal bar with arrow glyphs between tabs.
//
// Demonstrates:
//   - Powerline  /  glyphs baked into tab format strings for arrow transitions
//   - {mode_cap} with auto-colour derived from fill directive
//   - cap_bg for the background behind cap arrows
//   - fill directive on mode + active tab for colour propagation
//   - Full 14-mode per-mode colours
//   - Nord palette (distinct from Catppuccin used in default/)

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // -- Nord palette --
                // Polar Night (dark backgrounds)
                color_nord0  "#2e3440"
                color_nord1  "#3b4252"
                color_nord2  "#434c5e"
                color_nord3  "#4c566a"
                // Snow Storm (light foregrounds)
                color_nord4  "#d8dee9"
                color_nord5  "#e5e9f0"
                color_nord6  "#eceff4"
                // Frost (blues/cyans)
                color_frost0 "#8fbcbb"
                color_frost1 "#88c0d0"
                color_frost2 "#81a1c1"
                color_frost3 "#5e81ac"
                // Aurora (accent colours)
                color_red    "#bf616a"
                color_orange "#d08770"
                color_yellow "#ebcb8b"
                color_green  "#a3be8c"
                color_purple "#b48ead"

                // --- Left zone: mode pill with powerline cap, then tabs ---
                // {mode_cap} renders  with fg auto-derived from mode's fill bg.
                format_1_left "{mode}{mode_cap}{tabs}"

                // --- Right zone: notifications, then powerline  caps pointing left, then widgets ---
                format_2_right "{notifications}"
                format_3_right "#[bg=$nord1,fg=$nord0]#[bg=$nord1,fg=$nord4] {session} #[bg=$nord0,fg=$nord1]"
                format_4_right "#[bg=$nord2,fg=$nord0]#[bg=$nord2,fg=$nord5] {datetime} #[bg=$nord0,fg=$nord2]"

                // Cap config: background behind cap arrows.
                cap_bg "$nord0"

                // Spacer fill between zones.
                format_space "#[bg=$nord0]"

                // Zone priority for narrow terminals.
                format_precedence         "132"
                format_hide_on_overlength "true"

                // --- Tab format strings ---
                // Each tab has  at the start and  at the end, with colour
                // transitions creating the powerline arrow effect.
                // No tab_separator needed — the arrows ARE the separators.
                tab_active               "#[bg=$frost1,fg=$nord0]#[bg=$frost1,fg=$nord0,bold,fill] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification} #[bg=$nord0,fg=$frost1]"
                tab_active_fullscreen    "#[bg=$frost1,fg=$nord0]#[bg=$frost1,fg=$nord0,bold,fill] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification} #[bg=$nord0,fg=$frost1]"
                tab_active_sync          "#[bg=$frost1,fg=$nord0]#[bg=$frost1,fg=$nord0,bold,fill] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification} #[bg=$nord0,fg=$frost1]"
                tab_max_name_length      18
                tab_normal               "#[bg=$nord1,fg=$nord0]#[bg=$nord1,fg=$nord4] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification}#[bg=$nord0,fg=$nord1]"
                tab_normal_fullscreen    "#[bg=$nord1,fg=$nord0]#[bg=$nord1,fg=$nord4] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification}#[bg=$nord0,fg=$nord1]"
                tab_normal_sync          "#[bg=$nord1,fg=$nord0]#[bg=$nord1,fg=$nord4] {index} {name} {fullscreen_indicator}{sync_indicator}{floating_indicator} {notification}#[bg=$nord0,fg=$nord1]"
                tab_rename               "#[bg=$frost1,fg=$nord0]#[bg=$frost1,fg=$nord0,bold,fill] RENAME #[bg=$nord0,fg=$frost1]"
                tab_separator            ""
                tab_start_index          1
                tab_indicator_fullscreen "󰊓"
                tab_indicator_sync       ""
                tab_indicator_floating   "󰹙"

                // --- Notifications ---
                notification_enabled               "true"
                notification_format                "#[bg=$nord0,fg=$orange,bold] {count} "
                notification_format_completed      "#[fg=$green,bold]{icon}"
                notification_format_in_progress    "{icon}"
                notification_format_tab            "{icon}"
                notification_format_waiting        "#[fg=$yellow,bold]{icon}"
                notification_indicator_completed   ""
                notification_indicator_in_progress "󰔛"
                notification_indicator_waiting     ""
                notification_show_if_empty         "false"

                // --- Mode widget ---
                // fill extends the mode bg colour across the bar and tells
                // {mode_cap} what colour to use for its  arrow.
                mode_enter_search "#[bg=$yellow,fg=$nord0,bold,fill] ENT-SEARCH "
                mode_locked       "#[bg=$red,fg=$nord0,bold,fill] LOCKED "
                mode_move         "#[bg=$frost0,fg=$nord0,bold,fill] MOVE "
                mode_normal       "#[bg=$frost2,fg=$nord0,bold,fill] NORMAL "
                mode_pane         "#[bg=$orange,fg=$nord0,bold,fill] PANE "
                mode_prompt       "#[bg=$red,fg=$orange,bold,fill] PROMPT "
                mode_rename_pane  "#[bg=$orange,fg=$nord0,bold,fill] RENAMEPANE "
                mode_rename_tab   "#[bg=$green,fg=$nord0,bold,fill] RENAMETAB "
                mode_resize       "#[bg=$frost0,fg=$nord0,bold,fill] RESIZE "
                mode_scroll       "#[bg=$orange,fg=$nord0,bold,fill] SCROLL "
                mode_search       "#[bg=$yellow,fg=$nord0,bold,fill] SEARCH "
                mode_session      "#[bg=$purple,fg=$nord0,bold,fill] SESSION "
                mode_tab          "#[bg=$green,fg=$nord0,bold,fill] TAB "
                mode_tmux         "#[bg=$frost1,fg=$nord0,bold,fill] TMUX "

                // --- DateTime ---
                datetime_format   "%H:%M"
                datetime_timezone "America/Los_Angeles"
            }
        }
    }

    // Guide tab — opens first so users land here on launch.
    // less shows the guide from the top (scrollable); pressing q
    // drops into a live shell for trying the notification commands.
    // Relative path assumes launch from project root.
    tab name="guide" {
        pane command="bash" {
            args "-c" "less examples/GUIDE.txt; exec bash"
        }
    }

    tab name="powerline-1" {
        pane
    }

    tab name="powerline-2" {
        pane
        pane
    }

    tab name="powerline-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
