// Smallest working config — copy and customize.
//
// This example uses just 3 colours and 3 widgets (mode, tabs, session).
// Everything else is optional — add features one at a time from the
// other examples.

layout {
    // default_tab_template defines the layout for tabs declared in this file.
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "horizontal"

                // Three colours — that's all you need.
                color_bg     "#1e1e2e"
                color_fg     "#cdd6f4"
                color_accent "#a6e3a1"

                // One section on each side of the bar.
                format_1_left  "#[fg=$accent,bold]{mode} {tabs}"
                format_2_right "{notifications}"
                format_3_right "#[fg=$fg] {session} "

                // Plain tab styling — no powerline, no separators.
                tab_normal "#[fg=$fg] {index}:{name} {notification}"
                tab_active "#[fg=$bg,bg=$accent,bold] {index}:{name} {notification} #[bg=default]"

                // --- Notifications ---
                notification_enabled        "true"
                notification_icon_waiting   "⏳"
                notification_icon_in_progress "🔄"
                notification_icon_completed "✅"
                notification_format         "#[fg=$accent,bold] {count} "
                notification_show_if_empty  "false"
            }
        }
    }

    // Guide tab — opens first so users land here on launch.
    // less shows the guide from the top (scrollable); pressing q
    // drops into a live shell for trying the notification commands.
    // Relative path assumes launch from project root.
    tab name="guide" {
        pane command="bash" {
            args "-c" "less examples/GUIDE.txt; exec bash"
        }
    }

    tab name="tab-1" {
        pane
    }

    tab name="tab-2" {
        pane
    }
}
