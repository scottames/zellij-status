// Development layout for zellij-status
// Left sidebar: the plugin in vertical tab mode
// Right area: shell panes for testing

layout {
    default_tab_template {
        pane size=20 borderless=true {
            plugin location="file:target/wasm32-wasip1/debug/zellij-status.wasm" {
                layout_mode "vertical"

                // Catppuccin Mocha colour aliases
                color_bg      "#1e1e2e"
                color_fg      "#cdd6f4"
                color_accent  "#a6e3a1"
                color_muted   "#6c7086"
                color_surface "#313244"

                // Tab format strings
                tab_normal   " {index} {name} "
                tab_active   "#[fg=$bg,bg=$accent,fill] {index} {name} "
                tab_normal_fullscreen   " {index} {name} 󰊓 "
                tab_active_fullscreen   "#[fg=$bg,bg=$accent,fill] {index} {name} 󰊓 "
                tab_normal_sync   " {index} {name}  "
                tab_active_sync   "#[fg=$bg,bg=$accent,fill] {index} {name}  "
                tab_rename   "#[fg=$accent,italic] {index} {name} "
                tab_separator "#[fg=$muted]─"

                overflow_above  "#[fg=$muted]  ^ +{count}"
                overflow_below  "#[fg=$muted]  v +{count}"

                max_name_length 18
                padding_top     0
                border          "#[fg=$muted]│"
                start_index     1
            }
        }
        children
    }

    tab name="dev-1" {
        pane
    }

    tab name="dev-2" {
        pane
        pane
    }

    tab name="dev-3" {
        pane split_direction="vertical" {
            pane
            pane
        }
    }
}
